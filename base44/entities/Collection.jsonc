{
  "name": "Collection",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the collection e.g. 'Action Favorites'"
    },
    "media_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Array of media IDs in this collection"
    },
    "description": {
      "type": "string",
      "description": "Optional description of this collection",
      "maxLength": 1000
    }
  },
  "required": [
    "name"
  ],
  "rls": {
    "create": {
      "created_by_id": "{{user.id}}"
    },
    "read": {
      "created_by_id": "{{user.id}}"
    },
    "update": {
      "created_by_id": "{{user.id}}"
    },
    "delete": {
      "created_by_id": "{{user.id}}"
    }
  }
}