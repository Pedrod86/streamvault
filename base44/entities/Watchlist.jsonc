{
  "name": "Watchlist",
  "type": "object",
  "properties": {
    "media_id": {
      "type": "string",
      "description": "Reference to the media item"
    },
    "description": {
      "type": "string",
      "description": "Optional notes about this watchlist entry",
      "maxLength": 1000
    }
  },
  "required": [
    "media_id"
  ],
  "rls": {
    "create": {
      "created_by": "{{user.email}}"
    },
    "read": {
      "created_by": "{{user.email}}"
    },
    "update": {
      "created_by": "{{user.email}}"
    },
    "delete": {
      "created_by": "{{user.email}}"
    }
  }
}